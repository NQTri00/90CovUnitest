{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TestPlan",
  "type": "object",
  "properties": {
    "plan_version": { "type": "string" },
    "target_coverage": { "type": "integer" },
    "test_cases": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "service": { "type": "string" },
          "method": { "type": "string" },
          "test_id": { "type": "string" },
          "type": { "type": "string", "enum": ["happy_path", "edge_case", "error_path", "business"] },
          "description": { "type": "string" },
          "setup": {
            "type": "object",
            "properties": {
              "mocks": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "dependency": { "type": "string" },
                    "method": { "type": "string" },
                    "behavior": { "type": "string", "enum": ["return", "throw", "do_nothing"] },
                    "return_value": { "type": "string" }
                  },
                  "required": ["dependency", "method", "behavior"]
                }
              }
            },
            "required": ["mocks"]
          },
          "input": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "expected": {
            "type": "object",
            "properties": {
              "return_type": { "type": "string" },
              "assertions": {
                "type": "array",
                "items": { "type": "string" }
              },
              "verify_mocks": {
                "type": "array",
                "items": { "type": "string" }
              },
              "throws": { "type": ["string", "null"] },
              "exception_message_contains": { "type": ["string", "null"] }
            },
            "required": ["return_type", "assertions"]
          }
        },
        "required": ["service", "method", "test_id", "type", "description", "setup", "input", "expected"]
      }
    }
  },
  "required": ["plan_version", "target_coverage", "test_cases"]
}
