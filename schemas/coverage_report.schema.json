{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CoverageReport",
  "type": "object",
  "properties": {
    "total_coverage": { "type": "number" },
    "summary": {
      "type": "object",
      "properties": {
        "total_tests": { "type": "integer" },
        "passed": { "type": "integer" },
        "failed": { "type": "integer" },
        "skipped": { "type": "integer" }
      },
      "required": ["total_tests", "passed", "failed", "skipped"]
    },
    "classes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "line_coverage": { "type": "number" },
          "branch_coverage": { "type": ["number", "null"] },
          "uncovered_lines": {
            "type": "array",
            "items": { "type": "integer" }
          }
        },
        "required": ["line_coverage", "uncovered_lines"]
      }
    },
    "failures": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "test_id": { "type": "string" },
          "error_message": { "type": "string" },
          "stack_trace": { "type": "string" }
        },
        "required": ["test_id", "error_message"]
      }
    }
  },
  "required": ["total_coverage", "summary", "classes", "failures"]
}
