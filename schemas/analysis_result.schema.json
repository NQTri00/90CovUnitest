{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AnalysisResult",
  "type": "object",
  "properties": {
    "repo": {
      "type": "object",
      "properties": {
        "path": { "type": "string" },
        "language": { "type": "string" },
        "framework": { "type": "string" },
        "version": { "type": ["string", "null"] },
        "build_tool": { "type": ["string", "null"] }
      },
      "required": ["path", "language", "framework"]
    },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "class_name": { "type": "string" },
          "package": { "type": "string" },
          "file_path": { "type": "string" },
          "annotations": {
            "type": "array",
            "items": { "type": "string" }
          },
          "methods": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "visibility": { "type": "string" },
                "params": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": { "type": "string" },
                      "type": { "type": "string" }
                    },
                    "required": ["name", "type"]
                  }
                },
                "return_type": { "type": "string" },
                "throws": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "annotations": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "complexity": { "type": "integer" },
                "priority": { "type": "string", "enum": ["HIGH", "MEDIUM", "LOW"] }
              },
              "required": ["name", "visibility", "params", "return_type", "complexity", "priority"]
            }
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field_name": { "type": "string" },
                "type": { "type": "string" },
                "category": { "type": "string", "enum": ["repository", "http_client", "message_queue", "cache", "service", "utility"] },
                "mock_strategy": { "type": "string" },
                "annotations": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              },
              "required": ["field_name", "type", "category", "mock_strategy"]
            }
          }
        },
        "required": ["class_name", "file_path", "methods", "dependencies"]
      }
    }
  },
  "required": ["repo", "services"]
}
